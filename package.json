{
  "name": "nuxtjs-drupal-stir",
  "version": "4.3.8",
  "main": "./nuxt.config.ts",
  "bin": {
    "stir-a11y": "./scripts/a11y/run.mjs"
  },
  "exports": {
    ".": "./nuxt.config.ts",
    "./presets/minimal": "./presets/minimal/nuxt.config.ts",
    "./presets/full": "./presets/full/nuxt.config.ts",
    "./layers/theme/app/assets/css/main": "./layers/theme/app/assets/css/main.css",
    "./*": "./*"
  },
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": "^22.13.0 || ^24.11.0 || >=26.0.0"
  },
  "files": [
    "config",
    "contracts/stir-tools/README.md",
    "contracts/stir-tools/v1",
    "layers",
    "presets",
    "scripts/a11y",
    "server",
    "nuxt.config.ts",
    "readme.md"
  ],
  "scripts": {
    "build": "nuxi build",
    "dev": "nuxi dev",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "css:generate-safelist": "node scripts/generate-safelist.mjs",
    "dev:prepare": "nuxi prepare",
    "lint": "eslint . --no-warn-ignored",
    "lint:fix": "eslint . --fix --no-warn-ignored",
    "perf:report": "node scripts/perf/report.mjs",
    "perf:presentation": "node scripts/perf/presentation-css.mjs",
    "perf:lighthouse": "node scripts/perf/lighthouse.mjs",
    "perf:lighthouse:local": "node scripts/perf/lighthouse-local.mjs",
    "audit:consumers": "node scripts/audit/consumers.mjs",
    "audit:preset-matrix": "node scripts/audit/preset-matrix.mjs",
    "audit:preset-components": "node scripts/audit/preset-components.mjs",
    "audit:preset-editorial-output": "node scripts/audit/preset-editorial-output.mjs",
    "audit:preset:auth-output": "node scripts/audit/preset-auth-output.mjs",
    "audit:preset-integrations-output": "node scripts/audit/preset-integrations-output.mjs",
    "audit:vnext-inventory": "node scripts/audit/vnext-inventory.mjs",
    "audit:vnext-inventory:check": "node scripts/audit/vnext-inventory.mjs --check",
    "contracts:sync": "node scripts/contracts/sync-stir-tools.mjs",
    "docs:sync-tech-stack": "node scripts/docs/sync-tech-stack.mjs",
    "test": "vitest run",
    "test:coverage": "node scripts/audit/coverage-ratchet.mjs",
    "test:a11y": "node scripts/a11y/run.mjs",
    "test:a11y:install": "node scripts/a11y/run.mjs install chromium",
    "test:a11y:report": "node scripts/a11y/run.mjs show-report playwright-report",
    "test:nuxt:runtime": "vitest run --config vitest.nuxt.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:consumer:typecheck": "pnpm dev:prepare && nuxi typecheck --cwd tests/fixtures/consumer-app",
    "test:consumer:build": "pnpm dev:prepare && nuxi build --cwd tests/fixtures/consumer-app",
    "test:preset:minimal:typecheck": "nuxi typecheck --cwd tests/fixtures/minimal-consumer",
    "test:preset:minimal:build": "nuxi build --cwd tests/fixtures/minimal-consumer",
    "test:preset:full:typecheck": "nuxi typecheck --cwd tests/fixtures/full-consumer",
    "test:preset:full:build": "nuxi build --cwd tests/fixtures/full-consumer",
    "test:presets": "pnpm audit:preset-matrix && pnpm test:preset:minimal:typecheck && pnpm test:preset:full:typecheck && pnpm test:preset:auth:typecheck && pnpm audit:preset-components && pnpm test:preset:minimal:build && pnpm test:preset:full:build && pnpm test:preset:auth:build && pnpm audit:preset:auth-output && pnpm audit:preset-editorial-output && pnpm audit:preset-integrations-output",
    "test:preset:auth:build": "nuxi build --cwd tests/fixtures/auth-consumer",
    "test:preset:auth:typecheck": "nuxi typecheck --cwd tests/fixtures/auth-consumer",
    "test:consumer:packed": "node scripts/audit/packed-consumer.mjs",
    "test:consumer": "pnpm test:consumer:typecheck && pnpm test:consumer:build && pnpm test:consumer:packed",
    "test:nuxt": "pnpm test:nuxt:runtime",
    "test:all": "pnpm test:coverage && pnpm test:nuxt && pnpm test:e2e && pnpm test:a11y",
    "test:watch": "vitest",
    "verify:core": "pnpm dev:prepare && pnpm audit:vnext-inventory:check && pnpm test:all && pnpm lint && pnpm typecheck && pnpm build",
    "verify:ci": "pnpm verify:core && pnpm test:consumer",
    "deps:update": "pnpm update",
    "deps:verify": "pnpm verify:ci",
    "deps:update:safe": "pnpm deps:update && pnpm docs:sync-tech-stack && pnpm deps:verify",
    "typecheck": "nuxi typecheck",
    "release": "release-it"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.118",
    "@internationalized/date": "^3.12.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.5.0",
    "@nuxt/scripts": "^1.3.1",
    "@nuxt/ui": "^4.10.0",
    "@nuxtjs/plausible": "^3.0.2",
    "@nuxtjs/robots": "^6.1.2",
    "@nuxtjs/sitemap": "^8.2.2",
    "@nuxtjs/turnstile": "^1.1.3",
    "@plausible-analytics/tracker": "^0.4.5",
    "@tiptap/core": "3.28.0",
    "@tiptap/extension-bullet-list": "3.28.0",
    "@tiptap/extension-code": "3.28.0",
    "@tiptap/extension-collaboration": "3.28.0",
    "@tiptap/extension-drag-handle": "3.28.0",
    "@tiptap/extension-drag-handle-vue-3": "3.28.0",
    "@tiptap/extension-heading": "3.28.0",
    "@tiptap/extension-horizontal-rule": "3.28.0",
    "@tiptap/extension-image": "3.28.0",
    "@tiptap/extension-link": "3.28.0",
    "@tiptap/extension-list-item": "3.28.0",
    "@tiptap/extension-mention": "3.28.0",
    "@tiptap/extension-node-range": "3.28.0",
    "@tiptap/extension-ordered-list": "3.28.0",
    "@tiptap/extension-placeholder": "3.28.0",
    "@tiptap/extensions": "3.28.0",
    "@tiptap/markdown": "3.28.0",
    "@tiptap/pm": "3.28.0",
    "@tiptap/starter-kit": "3.28.0",
    "@tiptap/suggestion": "3.28.0",
    "@tiptap/vue-3": "3.28.0",
    "@tiptap/y-tiptap": "3.0.7",
    "@vueuse/core": "^14.3.0",
    "jiti": "^2.7.0",
    "motion-v": "^2.3.0",
    "nostics": "^1.2.0",
    "nuxt": "^4.5.0",
    "nuxt-vitalizer": "^2.0.0",
    "nuxtjs-drupal-ce": "^2.7.0",
    "tailwindcss": "^4.3.3",
    "valibot": "^1.4.2"
  },
  "peerDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1"
  },
  "peerDependenciesMeta": {
    "@axe-core/playwright": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/schema": "^4.5.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "@vue/test-utils": "^2.4.11",
    "ajv": "6.15.0",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "h3": "^1.15.11",
    "happy-dom": "^20.11.0",
    "lighthouse": "^13.4.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "release-it": "^20.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "vue-tsc": "^2.2.12"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "hooks": {
      "before:init": "pnpm verify:ci"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": false
    }
  }
}
