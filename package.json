{
  "name": "nuxtjs-drupal-stir",
  "version": "4.3.8",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": "^22.13.0 || ^24.11.0 || >=26.0.0"
  },
  "scripts": {
    "build": "nuxi build",
    "dev": "nuxi dev",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "css:generate-safelist": "node scripts/generate-safelist.mjs",
    "postinstall": "nuxi prepare",
    "lint": "eslint . --no-warn-ignored",
    "lint:fix": "eslint . --fix --no-warn-ignored",
    "perf:report": "node scripts/perf/report.mjs",
    "perf:lighthouse": "node scripts/perf/lighthouse.mjs",
    "docs:sync-tech-stack": "node scripts/docs/sync-tech-stack.mjs",
    "test": "vitest run",
    "test:nuxt:runtime": "vitest run --config vitest.nuxt.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:consumer:typecheck": "nuxi typecheck --cwd tests/fixtures/consumer-app",
    "test:consumer:build": "nuxi build --cwd tests/fixtures/consumer-app",
    "test:consumer": "pnpm test:consumer:typecheck && pnpm test:consumer:build",
    "test:nuxt": "pnpm test:nuxt:runtime",
    "test:all": "pnpm test && pnpm test:nuxt && pnpm test:e2e",
    "test:watch": "vitest",
    "verify:core": "pnpm test:all && pnpm lint && pnpm typecheck && pnpm build",
    "verify:ci": "pnpm verify:core && pnpm test:consumer",
    "deps:update": "pnpm update",
    "deps:verify": "pnpm verify:ci",
    "deps:update:safe": "pnpm deps:update && pnpm docs:sync-tech-stack && pnpm deps:verify",
    "typecheck": "nuxi typecheck",
    "release": "release-it"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.116",
    "@internationalized/date": "^3.12.2",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/plausible": "^3.0.2",
    "@nuxtjs/robots": "^6.1.2",
    "@nuxtjs/sitemap": "^8.2.2",
    "@nuxtjs/turnstile": "^1.1.3",
    "@plausible-analytics/tracker": "^0.4.5",
    "@tiptap/core": "3.27.1",
    "@tiptap/extension-bullet-list": "3.27.1",
    "@tiptap/extension-heading": "3.27.1",
    "@tiptap/extension-link": "3.27.1",
    "@tiptap/extension-list-item": "3.27.1",
    "@tiptap/extension-ordered-list": "3.27.1",
    "@tiptap/pm": "3.27.1",
    "@tiptap/vue-3": "3.27.1",
    "@vueuse/core": "^14.3.0",
    "motion-v": "^2.3.0",
    "nuxt": "^4.4.8",
    "nuxt-vitalizer": "^2.0.0",
    "nuxtjs-drupal-ce": "^2.7.0",
    "tailwindcss": "^4.3.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/scripts": "^1.3.0",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^26.1.1",
    "@vue/test-utils": "^2.4.11",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "h3": "^1.15.11",
    "happy-dom": "^20.10.6",
    "lighthouse": "^13.4.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "release-it": "^20.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vue": "^3.5.39",
    "vue-tsc": "^2.2.12"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "hooks": {
      "before:init": "pnpm verify:ci"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "npm": {
      "publish": false
    }
  }
}
