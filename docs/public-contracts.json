{
  "schemaVersion": 1,
  "compatibilityPolicy": "preserve-within-major",
  "layers": ["core", "theme", "platform", "editorial", "analytics", "scripts", "webform", "auth"],
  "layerOrder": ["core", "theme", "platform", "editorial", "analytics", "scripts", "webform", "auth"],
  "packageExports": [
    ".",
    "./presets/minimal",
    "./presets/full",
    "./layers/theme/app/assets/css/main",
    "./*"
  ],
  "aliases": [
    "#stir/utils",
    "#stir/composables",
    "#stir/components",
    "#stir/types",
    "~/utils",
    "~/composables",
    "~/components",
    "~/types"
  ],
  "preferredAliases": ["#stir/utils", "#stir/composables", "#stir/components", "#stir/types"],
  "compatibilityAliases": ["~/utils", "~/composables", "~/components", "~/types"],
  "componentConventions": {
    "customElements": "kebab-case 1:1 filenames under components/global",
    "fallbackSuffix": "--default"
  },
  "serverRoutes": [
    "/api/app-context",
    "/api/drupal-ce/**",
    "/api/listings/:listing",
    "/api/menu/**",
    "/api/paragraph/:paragraphId/text",
    "/api/seo/global",
    "/api/webform/submit",
    "/api/auth/**",
    "/api/account/**"
  ],
  "publicComposables": [
    "useStirListing"
  ],
  "runtimeConfigEnvironment": [
    "DRUPAL_URL",
    "DRUPAL_API_KEY",
    "NUXT_URL",
    "NUXT_NAME",
    "NUXT_ENV",
    "NUXT_INDEXABLE",
    "SERVER_DOMAIN_CLIENT",
    "TURNSTILE_KEY",
    "TURNSTILE_SECRET"
  ],
  "candidateDeprecations": [
    "useApiListing",
    "useDynamicListingControls",
    "layers/auth/server/utils/drupalHeaders"
  ],
  "removalPolicy": "Search all validation consumers, document a replacement, deprecate for at least one compatible release, and remove only in a major release."
}
