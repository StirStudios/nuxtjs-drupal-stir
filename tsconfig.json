{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#app": ["./node_modules/nuxt/dist/app"],
      "#app/*": ["./node_modules/nuxt/dist/app/*"],
      "#components": ["./.nuxt/components"],
      "#components/*": ["./.nuxt/components/*"],
      "#stir/utils": ["./layers/theme/app/utils"],
      "#stir/utils/*": ["./layers/theme/app/utils/*"],
      "#stir/composables": ["./layers/theme/app/composables"],
      "#stir/composables/*": ["./layers/theme/app/composables/*"],
      "#stir/components": ["./layers/theme/app/components"],
      "#stir/components/*": ["./layers/theme/app/components/*"],
      "#stir/types": ["./layers/theme/app/types"],
      "#stir/types/*": ["./layers/theme/app/types/*"],
      "#stir-webform/utils": ["./layers/webform/app/utils"],
      "#stir-webform/utils/*": ["./layers/webform/app/utils/*"],
      "#stir-webform/composables": ["./layers/webform/app/composables"],
      "#stir-webform/composables/*": ["./layers/webform/app/composables/*"],
      "~/utils": ["./layers/theme/app/utils"],
      "~/utils/*": ["./layers/theme/app/utils/*"],
      "~/composables": ["./layers/theme/app/composables"],
      "~/composables/*": ["./layers/theme/app/composables/*"],
      "~/components": ["./layers/theme/app/components"],
      "~/components/*": ["./layers/theme/app/components/*"],
      "~/types": ["./layers/theme/app/types"],
      "~/types/*": ["./layers/theme/app/types/*"]
    }
  },
  "exclude": ["tests/fixtures/consumer-app"]
}
