{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stirstudios.dev/contracts/v1/account-snapshot.schema.json",
  "title": "Stir account snapshot",
  "type": "object",
  "additionalProperties": true,
  "required": ["authenticated", "uid", "name", "mail", "roles"],
  "properties": {
    "authenticated": { "type": "boolean" },
    "uid": { "type": "integer", "minimum": 0 },
    "name": { "type": "string" },
    "account_name": { "type": "string" },
    "mail": { "type": "string" },
    "roles": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "authenticated": { "const": false } },
        "required": ["authenticated"]
      },
      "then": {
        "properties": {
          "uid": { "const": 0 },
          "roles": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "authenticated": { "const": true } },
        "required": ["authenticated"]
      },
      "then": {
        "required": ["account_name"],
        "properties": { "uid": { "minimum": 1 } }
      }
    }
  ]
}
