{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stirstudios.dev/contracts/v1/account-settings-values.schema.json",
  "title": "Stir account settings values response",
  "type": "object",
  "additionalProperties": true,
  "required": ["fields", "values"],
  "properties": {
    "fields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["editable"],
        "properties": {
          "editable": { "type": "boolean" },
          "requires_current_password": { "type": "boolean" }
        }
      }
    },
    "values": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
