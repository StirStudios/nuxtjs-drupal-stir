{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stirstudios.dev/contracts/v1/sitemap.schema.json",
  "title": "Stir sitemap response",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["loc", "lastmod", "changefreq", "priority"],
    "properties": {
      "loc": { "type": "string", "minLength": 1 },
      "lastmod": { "type": ["string", "null"] },
      "changefreq": { "type": ["string", "null"] },
      "priority": { "type": ["number", "null"] }
    }
  }
}
