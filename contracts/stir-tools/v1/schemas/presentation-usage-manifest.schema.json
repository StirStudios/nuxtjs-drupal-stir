{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stirstudios.dev/contracts/v1/presentation-usage-manifest.schema.json",
  "title": "Presentation usage manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "site",
    "capabilities",
    "used",
    "legacyClasses",
    "diagnostics",
    "revision"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uuid", "name", "theme"],
      "properties": {
        "uuid": { "type": "string" },
        "name": { "type": "string" },
        "theme": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "carousel",
          "hero",
          "layout",
          "media",
          "paragraphs",
          "semantic-presentation",
          "view",
          "webform"
        ]
      }
    },
    "used": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grid", "spacing", "width", "alignment"],
      "properties": {
        "grid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["columns", "gap", "matrix"],
          "properties": {
            "columns": { "$ref": "#/definitions/gridColumns" },
            "gap": { "$ref": "#/definitions/gridGap" },
            "matrix": { "type": "boolean" }
          }
        },
        "spacing": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(p|m)(t|r|b|l|x|y)?-(0|[1-5]|10|15|20)$"
          }
        },
        "width": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["w-xs", "w-sm", "w-md", "w-lg", "w-xl", "w-2xl"]
          }
        },
        "alignment": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "justify_left",
              "justify_center",
              "justify_right",
              "align_top",
              "align_center",
              "align_bottom",
              "text_left",
              "text_center",
              "text_right"
            ]
          }
        }
      }
    },
    "legacyClasses": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "maxLength": 80,
        "pattern": "^(?:(?:xs|sm|md|lg|xl|2xl):)?(?:hidden|block|flex|grid|list-none|aspect-(?:video|square)|text-muted|m-auto|mx-auto|(?:grid-cols|columns|col-span)-[1-9][0-9]*|basis-(?:full|1/[1-9][0-9]*)|gap-(?:[0-9]|1[0-9]|20)|space-y-(?:[1-9]|10|20)|(?:p|m)(?:[trblxy])?-(?:0|[1-5]|10|15|20)|(?:max-)?w-(?:xs|sm|md|lg|xl|2xl|3xl|4xl|5xl|6xl))$"
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rejectedLegacyClassCount"],
      "properties": {
        "rejectedLegacyClassCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "revision": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "definitions": {
    "gridColumns": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^(default|xs|sm|md|lg|xl|2xl)$": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1, "maximum": 12 }
        }
      }
    },
    "gridGap": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^(default|xs|sm|md|lg|xl|2xl)$": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 0, "maximum": 20 }
        }
      }
    }
  }
}
