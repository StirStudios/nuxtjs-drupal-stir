{
  "schemaVersion": 1,
  "contractVersion": "1.5.0",
  "producer": "stirstudios/stir_tools",
  "platformRequirements": {
    "drupalCore": "^11",
    "php": ">=8.4"
  },
  "compatibility": {
    "additiveChanges": "same-major",
    "breakingChanges": "new-major",
    "consumerReleaseLockstep": false
  },
  "capabilities": {
    "account.registration": {
      "providerModules": ["stir_account"],
      "optional": true
    },
    "account.ui": {
      "providerModules": ["stir_account"],
      "optional": true
    },
    "layout.webform": {
      "providerModules": ["stir_layout_builder_paragraph_webform"],
      "optional": true
    },
    "app.context": {
      "providerModules": ["stir_layout_block"],
      "optional": true
    },
    "seo.global": {
      "providerModules": ["stir_seo"],
      "optional": true
    }
  },
  "contracts": {
    "app.context": {
      "capability": "app.context",
      "schema": "schemas/app-context.schema.json",
      "fixtures": ["fixtures/app-context.json"]
    },
    "auth.register.response": {
      "capability": "account.registration",
      "schema": "schemas/auth-register-response.schema.json",
      "fixtures": [
        "fixtures/auth-register-admin-approval.json",
        "fixtures/auth-register-error.json"
      ]
    },
    "auth.register.policy": {
      "capability": "account.registration",
      "schema": "schemas/auth-register-policy.schema.json",
      "fixtures": [
        "fixtures/auth-register-policy-open.json",
        "fixtures/auth-register-policy-closed.json"
      ]
    },
    "auth.ui.config": {
      "capability": "account.ui",
      "schema": "schemas/auth-ui-config.schema.json",
      "fixtures": ["fixtures/auth-ui-config.json"]
    },
    "layout.webform": {
      "capability": "layout.webform",
      "schema": "schemas/webform.schema.json",
      "fixtures": ["fixtures/webform-contact.json"]
    },
    "seo.global": {
      "capability": "seo.global",
      "schema": "schemas/global-seo.schema.json",
      "fixtures": ["fixtures/global-seo.json"]
    }
  }
}
